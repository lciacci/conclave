# Secrets
.env
.env.*
!.env.example

# Python (tooling)
__pycache__/
*.pyc
.venv/
venv/

# v3 judge-eval boot artifacts — regenerated from a boot (judge_eval.py --generate),
# not source. Commit a specific run as a fixture later if reproducibility needs it.
orchestrator/eval_candidates.json
orchestrator/eval_judgments_*.json
# Grader memo (judge_eval.py GradeCache). Live working copy; the frozen run is
# committed under eval_fixtures/, which is what makes --score reproducible for $0.
orchestrator/eval_grade_cache.json
orchestrator/eval_report_*.json

