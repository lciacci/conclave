#!/bin/bash
# First-boot setup: tailscale join, EFS mount, one vLLM per model, LiteLLM front.
# cloud-init runs this once; tailscaled state + fstab + docker restart policy
# survive stop/start cycles.
set -euxo pipefail
exec > /var/log/conclave-init.log 2>&1

# --- tailscale ---
curl -fsSL https://tailscale.com/install.sh | sh
command -v aws || apt-get install -y awscli
set +x  # don't leak secrets into the boot log
TS_KEY=$(aws ssm get-parameter --name "${ts_key_param}" --with-decryption \
  --region "${region}" --query Parameter.Value --output text)
tailscale up --authkey "$TS_KEY" --hostname conclave-gpu
unset TS_KEY
set -x

# --- EFS model cache ---
apt-get install -y nfs-common
mkdir -p /mnt/efs
echo "${efs_dns}:/ /mnt/efs nfs4 defaults,_netdev 0 0" >> /etc/fstab
mount -a
mkdir -p /mnt/efs/models

# --- HF token (only gated models need it; empty for ungated Qwen) ---
set +x
HF_TOKEN=$(aws ssm get-parameter --name "${hf_token_param}" --with-decryption \
  --region "${region}" --query Parameter.Value --output text 2>/dev/null || true)
HF_ENV=""
if [ -n "$HF_TOKEN" ] && [ "$HF_TOKEN" != "PASTE-HERE" ]; then
  HF_ENV="-e HF_TOKEN=$HF_TOKEN"
fi
set -x

# --- vLLM fleet (one container per model, co-resident on the L40S) ---
# --enforce-eager on every model: frees CUDA-graph memory for KV and avoids the
# capture spike (learned v1) — doubly important with 3 processes sharing 48 GB.
# STARTED ONE AT A TIME, in models-var order, waiting for each to finish loading
# before the next: vLLM 0.24 checks FREE mem >= mem_util*TOTAL at each process's
# startup, so each model's free-check must run against real predecessor residency.
# The utils are additive per-slice (see the models var); starting them in parallel
# races the free-checks and a later model fails ("less than desired GPU memory
# utilization") or crash-loops. Model set is JSON from Terraform.
apt-get install -y jq
echo '${models_json}' > /etc/conclave-models.json

jq -c '.[]' /etc/conclave-models.json | while read -r m; do
  name=$(echo "$m" | jq -r .name)
  repo=$(echo "$m" | jq -r .repo)
  port=$(echo "$m" | jq -r .port)
  util=$(echo "$m" | jq -r .mem_util)
  maxlen=$(echo "$m" | jq -r .max_len)
  dtype=$(echo "$m" | jq -r .dtype)
  dtype_arg=""
  [ -n "$dtype" ] && [ "$dtype" != "null" ] && dtype_arg="--dtype $dtype"
  # Image PINNED to v0.24.0 (was :latest, which resolved to v0.24.0 on the
  # 2026-07-10 boot). Pinning stops a silent vLLM bump from changing mem-util
  # semantics or detokenizer behaviour under us between boots.
  docker run -d --restart unless-stopped --name "vllm-$name" --gpus all \
    -v /mnt/efs/models:/models -p "$port":8000 \
    $HF_ENV \
    vllm/vllm-openai:v0.24.0 \
    --model "$repo" \
    --served-model-name "$name" \
    --download-dir /models \
    --max-model-len "$maxlen" \
    --gpu-memory-utilization "$util" \
    $dtype_arg \
    --enforce-eager

  # Wait for this model to finish loading before starting the next, so the next
  # one's ceiling profiles against real residency. Bounded (~8 min) so a single
  # stuck model can't hang the whole boot — unless-stopped lets it keep retrying
  # while later models come up. `if`-form keeps the failing grep clear of set -e.
  echo "waiting for vllm-$name to load..."
  for _ in $(seq 1 96); do
    if docker logs "vllm-$name" 2>&1 | grep -q "Application startup complete"; then
      echo "vllm-$name ready"; break
    fi
    sleep 5
  done
done

# --- LiteLLM gateway (one OpenAI-compatible API in front of all backends) ---
# Generated from the same model list = single source of truth. --network host so
# it reaches the vLLM containers on localhost:<port>. Reachable at :4000 over
# Tailscale; per-model cost accounting + routing live here (v2 goal).
{
  echo "model_list:"
  jq -c '.[]' /etc/conclave-models.json | while read -r m; do
    name=$(echo "$m" | jq -r .name)
    port=$(echo "$m" | jq -r .port)
    cin=$(echo "$m" | jq -r .cost_in)
    cout=$(echo "$m" | jq -r .cost_out)
    echo "  - model_name: $name"
    echo "    litellm_params:"
    echo "      model: openai/$name"
    echo "      api_base: http://localhost:$port/v1"
    echo "      api_key: none"
    # Per-model cost attribution (GPU-amortization placeholders; see models var).
    echo "      input_cost_per_token: $cin"
    echo "      output_cost_per_token: $cout"
  done
  # Log each call's per-model spend so cost accounting is visible in the litellm
  # container logs (docker logs litellm). Full persistence would add a Postgres
  # backend; v2 is single-user, stdout logging is enough to learn the pattern.
  echo "litellm_settings:"
  echo "  success_callback: [\"logging\"]"
  echo "  drop_params: true"
} > /etc/litellm-config.yaml

# LITELLM_LOG=DEBUG: the only level that emits per-request `response_cost` to
# stdout — the `success_callback: ["logging"]` above registers the per-token
# costs but never prints them (verified 2026-07-08). Noisy (dumps request params
# per call) but v2 is single-user and learning the cost pattern is the goal;
# `docker logs litellm | grep response_cost` extracts the signal.
docker run -d --restart unless-stopped --name litellm --network host \
  -e LITELLM_LOG=DEBUG \
  -v /etc/litellm-config.yaml:/app/config.yaml \
  ghcr.io/berriai/litellm:main-latest \
  --config /app/config.yaml --port 4000

# --- idle-stop signal: publish GPU utilization to CloudWatch every minute ---
# The native CPU idle-stop misses that inference work is on the GPU, not the CPU
# (a box with 3 models loaded but no requests sits at low CPU AND low GPU; a box
# mid-generation is low CPU but high GPU). Publishing GPU util lets the alarm
# stop the box only when NO inference has run for the window. Quoted heredoc so
# $(...) / $VAR stay literal in the script; only $${region} is templated in.
cat > /usr/local/bin/pub-gpu-util.sh <<'PUBEOF'
#!/bin/bash
IID=$(curl -s http://169.254.169.254/latest/meta-data/instance-id)
U=$(nvidia-smi --query-gpu=utilization.gpu --format=csv,noheader,nounits | head -1)
aws cloudwatch put-metric-data --namespace Conclave --metric-name GPUUtil \
  --dimensions InstanceId="$IID" --value "$U" --region ${region}
PUBEOF
chmod +x /usr/local/bin/pub-gpu-util.sh
echo "* * * * * root /usr/local/bin/pub-gpu-util.sh" > /etc/cron.d/conclave-gpu-util
